# ===== LLM Backend Selection =====
# "openai" = OpenAI-compatible API (default), "claude_code" = Claude Code headless mode
LLM_BACKEND=openai

# ===== OpenAI-compatible API Config (used when LLM_BACKEND=openai) =====
# Recommended: Alibaba Bailian platform qwen-plus model: https://bailian.console.aliyun.com/
# Note: resource consumption can be significant, try simulations under 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Claude Code Headless Config (used when LLM_BACKEND=claude_code) =====
# Requires Claude Code CLI installed and logged in: https://code.claude.com
# CLAUDE_CODE_BIN=claude
# CLAUDE_CODE_MODEL=claude-opus-4-6
# CLAUDE_CODE_TIMEOUT=300

# ===== Claude OpenAI Proxy (use Claude Code for OASIS simulations too) =====
# Start proxy: cd backend && unset CLAUDECODE && uv run python scripts/claude_openai_proxy.py
# Then set these values so CAMEL-AI routes through the proxy:
# LLM_API_KEY=sk-claude-proxy
# LLM_BASE_URL=http://localhost:8082/v1
# LLM_MODEL_NAME=claude-sonnet-4-20250514

# ===== Zep Memory Graph Config =====
# Free monthly quota is sufficient for basic use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Config (optional) =====
# Note: if not using boost config, do not include the following entries in .env
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
